{
  "author": {
    "name": "K.Adam White",
    "url": "http://www.kadamwhite.com"
  },
  "name": "wpapi",
  "version": "2.0.0-alpha.1",
  "description": "An isomorphic JavaScript client for interacting with the WordPress REST API",
  "main": "./dist/index.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/wp-api/node-wpapi.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wp-api/node-wpapi/issues"
  },
  "homepage": "https://github.com/wp-api/node-wpapi",
  "keywords": [
    "api",
    "client",
    "cms",
    "wordpress"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rimraf dist && tsdown",
    "env:cli": "npx @wordpress/env run cli",
    "env:db": "npx @wordpress/env run cli -- mysql -uroot -ppassword wordpress --host=mysql",
    "env:destroy": "npx @wordpress/env destroy",
    "env:logs": "npx @wordpress/env logs development | grep -v -E '\"(GET|OPTIONS|HEAD|POST|PUT)'",
    "env:seed": "bash bin/seed-wp-env.sh",
    "env:start": "npx @wordpress/env start",
    "env:stop": "npx @wordpress/env stop",
    "update-default-routes-json": "node build/scripts/update-default-routes-json",
    "predocs": "rimraf documentation/api-reference",
    "docs": "jsdoc -c .jsdoc.json --verbose",
    "jekyll": "node bin/jekyll",
    "release-docs": "node build/scripts/release-docs",
    "release-npm": "npm run build && npm test && npm publish",
    "eslint": "eslint .",
    "lint": "npm run eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch": "vitest",
    "test:all": "vitest run",
    "test:unit": "vitest run tests/unit fetch/tests/unit superagent/tests/unit",
    "test:integration": "vitest run tests/integration --no-file-parallelism",
    "test:ci": "npm run eslint && vitest run tests/unit fetch/tests/unit superagent/tests/unit --coverage",
    "pretest": "npm run lint || true",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "li": "^1.3.0",
    "parse-link-header": "^1.0.1",
    "qs": "^6.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@vitest/coverage-v8": "^4.1.10",
    "combyne": "^2.0.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jsdoc": "^3.6.2",
    "kramed": "^0.5.6",
    "minami": "^1.2.3",
    "minimist": "^1.2.0",
    "prettier": "^3.9.5",
    "prompt": "^1.0.0",
    "rimraf": "^2.6.3",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./fetch": {
      "import": "./dist/fetch.mjs",
      "require": "./dist/fetch.cjs"
    },
    "./superagent": {
      "import": "./dist/superagent.mjs",
      "require": "./dist/superagent.cjs"
    },
    "./package.json": "./package.json"
  },
  "inlinedDependencies": {
    "call-bind-apply-helpers": "1.0.2",
    "call-bound": "1.0.4",
    "dunder-proto": "1.0.1",
    "es-define-property": "1.0.1",
    "es-errors": "1.3.0",
    "es-object-atoms": "1.1.2",
    "function-bind": "1.1.2",
    "get-intrinsic": "1.3.0",
    "get-proto": "1.0.1",
    "gopd": "1.2.0",
    "has-symbols": "1.1.0",
    "hasown": "2.0.4",
    "li": "1.3.0",
    "math-intrinsics": "1.1.0",
    "object-inspect": "1.13.4",
    "qs": "6.15.3",
    "side-channel": "1.1.1",
    "side-channel-list": "1.0.1",
    "side-channel-map": "1.0.1",
    "side-channel-weakmap": "1.0.2"
  }
}
